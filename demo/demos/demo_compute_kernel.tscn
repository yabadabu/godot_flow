"point_count_binding": 7,
"random_seed": 466698300,
"shader_file_path": "",
"shader_mode": 0,
"shader_source": "#version 450

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

// Input: per-point position, packed VEC4_PADDED (x, y, z, 0.0).
layout(set = 0, binding = 0, std430) restrict readonly buffer InPos {
	vec4 data[];
} in_pos;

// Output: per-point density (1 float per point).
layout(set = 0, binding = 1, std430) restrict writeonly buffer OutDensity {
	float data[];
} out_density;

// Point count params buffer.
layout(set = 0, binding = 7, std430) restrict readonly buffer Params {
	uint point_count;
} params;

void main() {
	uint idx = gl_GlobalInvocationID.x;
	if (idx >= params.point_count) {
		return;
	}
	// Grid is 16x16 on X/Z with step 1, so the centre is (7.5, 0, 7.5).
	vec3 p = in_pos.data[idx].xyz;
	vec3 centre = vec3(7.5, 0.0, 7.5);
	float dist = length(p - centre);
	// Radial falloff: 1.0 at the centre, decaying outward.
	out_density.data[idx] = 1.0 / (1.0 + dist);
}
",
"title": "Compute Kernel",
